@page "/"
@using Shared
@inject ProtossBot myStarcraftBot
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Starcraft Bot</PageTitle>

<LaunchControl />
@if(myStarcraftBot.InGame)
{
    <GameSpeedControl />
    <BuildOrderControl />
}


@code {
    protected override void OnInitialized()
    {
        myStarcraftBot.StatusChanged += Reload;
    }

    public void Dispose()
    {
        myStarcraftBot.StatusChanged -= Reload;
    }

    private void Reload() => InvokeAsync(StateHasChanged);
}